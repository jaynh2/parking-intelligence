# Copy to .env and adjust. All variables are optional — every one has a
# sane default in config/settings.py; this file documents what exists.

# ---- Security & auth --------------------------------------------------
# Comma-separated list of valid API keys. Empty = auth disabled (dev only).
# In production ALWAYS set this. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PCI_API_KEYS=257a89e20c199a9ad38939ee248f9603

# Secrets backend: env (default) | aws | vault
# env   : read directly from environment variables (this file)
# aws   : read from AWS Secrets Manager (requires boto3, PCI_AWS_SECRET_NAME, PCI_AWS_REGION)
# vault : read from HashiCorp Vault KV v2 (requires hvac, VAULT_TOKEN, PCI_VAULT_ADDR, PCI_VAULT_PATH)
PCI_SECRETS_BACKEND=env
PCI_AWS_SECRET_NAME=pci/prod-secrets
PCI_AWS_REGION=ap-south-1
PCI_VAULT_ADDR=http://localhost:8200
PCI_VAULT_PATH=secret/data/pci

# CORS — allowed request origins. Comma-separated. Default: local Streamlit only.
# In production: PCI_CORS_ORIGINS=https://dashboard.example.com
PCI_CORS_ORIGINS=http://localhost:8501

# Per-key rate limits (limits library notation: "N/period")
PCI_RATE_LIMIT_DEFAULT=200/minute
PCI_RATE_LIMIT_PREDICT=60/minute
PCI_RATE_LIMIT_MAP=20/minute

# "dask"    : chunked/batch processing over a flat CSV file (default).
# "postgis" : production spatial database, see pipeline/data_gateway.py.
PCI_DATA_BACKEND=dask
PCI_CSV_PATH=data/raw/violations.csv
PCI_CHUNK_SIZE=25000

PCI_POSTGIS_DSN=postgresql://user:password@localhost:5432/traffic_db
PCI_POSTGIS_TABLE=violations

# ---- Geofence / data quality -------------------------------------------
PCI_LAT_MIN=12.70
PCI_LAT_MAX=13.45
PCI_LON_MIN=77.30
PCI_LON_MAX=77.90
PCI_MAX_ROW_REJECTION_RATE=0.25

# ---- Clustering (Phase 1) ----------------------------------------------
PCI_CLUSTER_PARTITION_COLUMN=police_station
PCI_HDBSCAN_MIN_CLUSTER_SIZE=10

# ---- Heatmap (Phase 2) --------------------------------------------------
PCI_HEATMAP_MAX_POINTS=20000

# ---- Forecasting (Phase 5) ----------------------------------------------
PCI_MODEL_TEST_SIZE=0.2
PCI_XGB_N_ESTIMATORS=200
PCI_XGB_LEARNING_RATE=0.08
PCI_XGB_MAX_DEPTH=6

# ---- Enforcement engine (Phase 6) ---------------------------------------
PCI_GROWTH_RATE_CLIP_MIN=0.5
PCI_GROWTH_RATE_CLIP_MAX=3.0
PCI_URGENT_GROWTH_THRESHOLD=1.2
PCI_HIGH_PRIORITY_RECENCY_THRESHOLD=0.9

# ---- Artifacts / model registry -----------------------------------------
PCI_ARTIFACT_ROOT=artifacts
PCI_MODEL_VERSION=v1

# ---- API / service --------------------------------------------------------
PCI_API_HOST=0.0.0.0
PCI_API_PORT=8000
PCI_CACHE_TTL_SECONDS=60
PCI_LOG_LEVEL=INFO

# ---- Dashboard (read directly by dashboard/app.py, not config/settings.py) --
PCI_API_BASE_URL=http://localhost:8000
PCI_API_KEY=257a89e20c199a9ad38939ee248f9603  # set to a valid key from PCI_API_KEYS when auth is enabled
PCI_DASHBOARD_CACHE_TTL=60
